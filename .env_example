# Copy this to .env and adjust values for your setup.
# docker compose up reads these automatically.

NODE_ENV=development
HOST=0.0.0.0
PORT=9000

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1baddeed
POSTGRES_DATABASE=postgres

# Optional: set a custom Postgres connection string instead of individual vars
# POSTGRES_URL=postgresql://postgres:1baddeed@localhost:5432/postgres

# Optional: API auth header (passed to REST routes)
# APAP_API_AUTH_HEADER=Bearer your-token-here

LOG_LEVEL=debug
